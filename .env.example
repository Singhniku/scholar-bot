# AI Provider: "gemini" (free tier) or "anthropic" (paid)
AI_PROVIDER=gemini

# Google Gemini API Key — FREE at https://aistudio.google.com
# Free limits: 15 req/min, 1 M tokens/min, 1 500 req/day
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic API Key — only needed if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# LinkedIn Credentials (optional — enables Auto Apply)
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Job Search Settings
DEFAULT_LOCATION=United States
DEFAULT_NUM_JOBS=50
JOB_SEARCH_DAYS=30

# Output Settings
OUTPUT_DIR=./output
