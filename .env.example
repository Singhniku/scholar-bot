# AI Provider: "gemini" (free tier) or "anthropic" (paid)
AI_PROVIDER=gemini

# Google Gemini API Key — FREE at https://aistudio.google.com
# Free limits: 15 req/min, 1 M tokens/min, 1 500 req/day
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic API Key — only needed if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── LinkedIn ──────────────────────────────────────────────────────────────
# Your public LinkedIn profile URL (optional). When set, it appears on the
# generated resume and pre-fills the "LinkedIn URL" field on Easy Apply forms.
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-handle

# Auto-Apply credentials (optional — ONLY needed if you want the bot to
# submit Easy Apply forms for you). Job search, matching, resume optimisation
# and all other features work without these.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Job Search Settings
DEFAULT_LOCATION=United States
DEFAULT_NUM_JOBS=50
JOB_SEARCH_DAYS=30

# Output Settings
OUTPUT_DIR=./output
